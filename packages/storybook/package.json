{
	"name": "terra-draw-storybook",
	"version": "0.0.1",
	"private": true,
	"description": "Storybook examples for Terra Draw components and features",
	"main": "src/index.ts",
	"scripts": {
		"storybook": "storybook dev -p 6006",
		"storybook:build": "storybook build",
		"storybook:build:memory": "NODE_OPTIONS=--max-old-space-size=4096 storybook build",
		"storybook:serve": "http-server storybook-static --port 6006 --silent",
		"storybook:test": "vitest --project=storybook",
		"storybook:help": "test-storybook --help"
	},
	"author": "James Milner",
	"license": "MIT",
	"dependencies": {
		"@arcgis/core": "4.31.6",
		"@googlemaps/js-api-loader": "2.0.2",
		"@types/leaflet": "1.9.15",
		"leaflet": "1.9.4",
		"mapbox-gl": "3.9.2",
		"maplibre-gl": "5.24.0",
		"ol": "10.9.0"
	},
	"devDependencies": {
		"@storybook/addon-docs": "^10.2.19",
		"@storybook/addon-vitest": "^10.2.19",
		"@storybook/html": "10.2.19",
		"@storybook/html-vite": "^10.2.19",
		"@storybook/mdx2-csf": "1.1.0",
		"@vitest/browser-playwright": "^4.1.0",
		"@vitest/coverage-v8": "^4.1.0",
		"http-server": "14.1.1",
		"playwright": "^1.58.2",
		"storybook": "10.2.19",
		"typescript": "5.6.3",
		"vitest": "^4.1.0"
	}
}
